{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*",       "destination": "https://swimtech-api.onrender.com/api/:path*" },
    { "source": "/auth/:path*",      "destination": "https://swimtech-api.onrender.com/auth/:path*" },
    { "source": "/customers/:path*", "destination": "https://swimtech-api.onrender.com/customers/:path*" },

    { "source": "/pool",             "destination": "https://swimtech-api.onrender.com/pool" },

    { "source": "/share/:path*",     "destination": "/share" },
    { "source": "/badges",           "destination": "/badge" },
    { "source": "/training-log",     "destination": "/training_log" },
    { "source": "/app",              "destination": "/landing" },
    { "source": "/",                 "destination": "/landing" }
  ]
}