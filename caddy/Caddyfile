# ================================================
# SwimTech — Caddyfile
# ================================================

# 자동 HTTP→HTTPS 리다이렉트 비활성화 (Cloudflare Tunnel 무한 루프 방지)
{
  auto_https disable_redirects
}

# -----------------------------------------------
# 공통 라우트 스니펫 (HTTP / HTTPS 공유)
# -----------------------------------------------
(swimtech_routes) {

  # 분석 관련 라우트 — 외부 접근 차단 (private 네트워크 + 로컬만 허용)
  @analysis_restricted {
    path /upload /viewer /meta /stream/*
    not {
      remote_ip private_ranges
    }
  }
  redir @analysis_restricted /landing 302

  # Flowise AI 챗봇
  handle /flowise/* {
    uri strip_prefix /flowise
    reverse_proxy swim-flowise:3000 {
      header_up Host {upstream_hostport}
    }
    header -X-Frame-Options
  }

  # Flower 모니터링 (내부용)
  handle /flower/* {
    uri strip_prefix /flower
    reverse_proxy swim-flower:5555
  }

  # MinIO 콘솔 (내부용)
  handle /minio/* {
    uri strip_prefix /minio
    reverse_proxy swim-minio:9001
  }

  # 나머지 모든 요청 → swim-api
  handle {
    reverse_proxy swim-api:8000
  }
}

# -----------------------------------------------
# HTTPS — 로컬 직접 접근 (자체 서명 인증서)
# -----------------------------------------------
localhost {
  import swimtech_routes

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
    X-XSS-Protection "1; mode=block"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://*.kakao.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://*.daumcdn.net; frame-src 'self' https://accounts.google.com https://kauth.kakao.com; connect-src 'self' https://accounts.google.com https://*.kakao.com https://kapi.kakao.com https://dapi.kakao.com https://*.daumcdn.net http://localhost:43000 https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.daumcdn.net https://*.kakaocdn.net https:; font-src 'self' data:; media-src 'self' blob:;"
    -Server
  }

  log {
    output file /data/logs/swimtech.log
    format json
  }
}

# -----------------------------------------------
# HTTP — Cloudflare Tunnel 지원 (모든 호스트, 리다이렉트 없음)
# -----------------------------------------------
:80 {
  import swimtech_routes
}
